---
import { SOCIAL_LINKS } from '../consts';
import { Icon } from 'astro-icon/components';
const today = new Date();
---

<footer>
	<div class="footer-content">
		<div class="footer-row">
			<p class="made-with">made with ❤️ & astro</p>
			<div class="footer-social">
				{SOCIAL_LINKS.map(link => (
					<a href={link.url} target={link.url.startsWith('mailto:') ? undefined : '_blank'} rel={link.url.startsWith('mailto:') ? undefined : 'noopener noreferrer'} class="social-icon" aria-label={link.label} title={link.label}>
						<Icon name={link.icon} size="14" />
					</a>
				))}
			</div>
		</div>
		<p class="copyright">&copy; {today.getFullYear()} Lokesh · halovessel</p>
	</div>
</footer>

<style>
	footer {
		border-top: 1px solid var(--border-2);
		padding: 1.5rem 2rem;
		margin-top: 4rem;
	}

	.footer-content {
		max-width: var(--max-width);
		margin: 0 auto;
	}

	.footer-row {
		display: flex;
		align-items: center;
		justify-content: space-between;
		margin-bottom: 0.5rem;
	}

	.made-with {
		font-family: var(--mono);
		font-size: 11px;
		color: var(--fg-dim);
		margin: 0;
	}

	.footer-social {
		display: flex;
		align-items: center;
		gap: 0.5rem;
	}

	.social-icon {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 28px;
		height: 28px;
		border-radius: var(--radius);
		color: var(--fg-dim);
		border: 1px solid var(--border-2);
		text-decoration: none;
		transition: color 0.15s ease, border-color 0.15s ease;
	}

	.social-icon:hover {
		color: var(--accent);
		border-color: var(--accent);
	}

	.copyright {
		font-family: var(--mono);
		font-size: 10px;
		color: var(--fg-dim);
		margin: 0;
		opacity: 0.6;
	}
</style>
