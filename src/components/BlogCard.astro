---
interface Props {
	title: string;
	description: string;
	date: Date;
	tags?: string[];
	slug: string;
	size?: string;
}

const { title, description, date, tags = [], slug, size = 'small' } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
	year: 'numeric',
	month: 'short',
	day: 'numeric',
});

const sizeClass = `bento-${size}`;

const tagColors: Record<string, string> = {
	tauri: 'tag-yellow',
	rust: 'tag-mint',
	astro: 'tag-lilac',
	guide: 'tag-orange',
	devlog: 'tag-pink',
};
---

<a href={`/blog/${slug}/`} class:list={["blog-card accent-bar", sizeClass]}>
	<div class="card-inner">
		<div class="card-top">
			<div class="card-tags">
				{tags.map(tag => (
					<span class:list={['post-tag', tagColors[tag.toLowerCase()] || 'tag-default']}>{tag}</span>
				))}
			</div>
			<span class="card-date">{formattedDate}</span>
		</div>
		<h3 class="card-title">{title}</h3>
		<p class="card-desc">{description}</p>
		<div class="card-footer">
			<span class="card-arrow">read →</span>
		</div>
	</div>
</a>

<style>
	.blog-card {
		display: block;
		padding: 20px;
		background: transparent;
		border: 1.5px dashed var(--border-2);
		border-radius: var(--radius);
		text-decoration: none;
		color: inherit;
		transition: background 0.15s ease;
		position: relative;
		overflow: hidden;
	}

	.blog-card:hover {
		background: var(--bg-card);
	}

	.card-inner {
		display: flex;
		flex-direction: column;
		height: 100%;
	}

	/* Bento sizes */
	.bento-large {
		grid-column: span 2;
	}

	.bento-large .card-title {
		font-size: 16px;
	}

	.bento-large .card-desc {
		-webkit-line-clamp: 4;
	}

	.bento-tall {
		grid-row: span 2;
	}

	.bento-tall .card-inner {
		justify-content: space-between;
	}

	.bento-tall .card-desc {
		-webkit-line-clamp: 6;
	}

	.bento-medium {
		grid-column: span 2;
	}

	.bento-small {
		/* default 1x1 */
	}

	.card-top {
		display: flex;
		align-items: center;
		gap: 10px;
		margin-bottom: 10px;
		flex-wrap: wrap;
	}

	.card-tags {
		display: flex;
		gap: 6px;
		flex-wrap: wrap;
	}

	.post-tag {
		font-size: 9px;
		font-weight: 700;
		padding: 2px 7px;
		border-radius: 2px;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		border: 1px solid;
	}

	.card-date {
		font-size: 10px;
		color: var(--fg-dim);
		margin-left: auto;
	}

	.card-title {
		font-size: 15px;
		font-weight: 700;
		color: var(--fg);
		margin: 0 0 6px 0;
		line-height: 1.3;
	}

	.card-desc {
		font-size: 11px;
		color: var(--fg-muted);
		margin: 0;
		line-height: 1.7;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
		flex: 1;
	}

	.card-footer {
		margin-top: 12px;
		display: flex;
		justify-content: flex-end;
	}

	.card-arrow {
		font-size: 11px;
		color: var(--accent);
		opacity: 0;
		transition: opacity 0.15s ease;
	}

	.blog-card:hover .card-arrow {
		opacity: 1;
	}

	@media (max-width: 768px) {
		.bento-large,
		.bento-medium {
			grid-column: span 2;
		}
	}

	@media (max-width: 640px) {
		.bento-large,
		.bento-tall,
		.bento-medium {
			grid-column: span 1;
			grid-row: span 1;
		}
	}
</style>
