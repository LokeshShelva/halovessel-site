---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import ScrollReveal from '../components/ScrollReveal.astro';
import { SITE_DESCRIPTION, SITE_TITLE, SOCIAL_LINKS } from '../consts';
import { Icon } from 'astro-icon/components';

const posts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 3);

// Tag color map
const tagColors: Record<string, string> = {
	tauri: 'tag-yellow',
	rust: 'tag-mint',
	astro: 'tag-lilac',
	guide: 'tag-orange',
	devlog: 'tag-pink',
};

function getTagClass(tag: string) {
	return tagColors[tag.toLowerCase()] || 'tag-default';
}
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main class="home-main">

			<!-- Hero -->
			<section class="hero">
				<div class="sticker-row animate-pop-in delay-1">
					<span class="sticker sticker-hover tag-mint">curious</span>
					<span class="sticker sticker-hover tag-yellow">open source</span>
					<span class="sticker sticker-hover tag-lilac">nerd</span>
					<span class="sticker sticker-hover tag-pink">terminal is home</span>
					<span class="sticker sticker-hover tag-orange">building in public</span>
				</div>

				<div class="hero-eyebrow animate-fade-up delay-2">
					hi, i'm <span class="accent">lokesh shelva</span> —
				</div>
				<h1 class="hero-name animate-fade-up delay-3">
					developer &<br><span class="squiggle">builder</span>
				</h1>

				<p class="hero-sub animate-fade-up delay-4">
					builds tools nobody asked for. writes about it anyway.<br>
					<strong>powered by mass amounts of caffeine and curiosity.</strong><br>
					currently over-engineering something simple.
				</p>

				<div class="cta-row animate-fade-up delay-5">
					<a href="mailto:5shelva19@gmail.com" class="cta cta-primary">say hello</a>
					<a href="/blog/" class="cta cta-ghost">read my writing</a>
					<a href="/projects/" class="cta cta-ghost">see my builds</a>
				</div>

				<div class="scroll-hint animate-fade-in delay-7">
					↓ scroll to see what's been <span class="accent">cooking</span>
				</div>
			</section>

			<!-- Recent writing -->
			<div class="divider animate-fade-in delay-8">recent writing</div>


			<ScrollReveal class="section reveal-stagger">
				{posts.length > 0 ? (
					<>
						<div class="post-list">
							{posts.map((post, i) => (
								<a href={`/blog/${post.id}/`} class="post-card accent-bar reveal" style={`--reveal-i: ${i}`}>
									<div class="post-meta">
										{post.data.tags?.map(tag => (
											<span class:list={['post-tag', getTagClass(tag)]}>{tag}</span>
										))}
										<span class="post-date">
											{post.data.pubDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
										</span>
									</div>
									<div class="post-title">{post.data.title}</div>
									<div class="post-excerpt">{post.data.description}</div>
									<div class="post-footer">
										<span class="post-arrow">read →</span>
									</div>
								</a>
							))}
						</div>
						<a href="/blog/" class="view-all reveal" style="--reveal-i: 4">
							<span>all writing</span>
							<span class="arrow">→</span>
						</a>
					</>
				) : (
					<div class="empty-state reveal">
						<span class="empty-prompt">$ ls blogs/</span>
						<p class="empty-text">ls: cannot access 'blogs/': No such file or directory</p>
					</div>
				)}
			</ScrollReveal>


		</main>
		<Footer />
	</body>
</html>

<style>
	.home-main {
		max-width: var(--max-width);
		margin: 0 auto;
		padding: 0 24px;
		min-height: calc(100vh - var(--header-height) - 100px);
	}

	/* Hero */
	.hero {
		padding: 48px 0 36px;
		position: relative;
	}

	.sticker-row {
		display: flex;
		gap: 8px;
		flex-wrap: wrap;
		margin-bottom: 28px;
	}

	.sticker {
		font-size: 10px;
		font-weight: 700;
		padding: 3px 9px;
		border-radius: 2px;
		letter-spacing: 0.05em;
		display: inline-block;
	}

	.hero-eyebrow {
		font-size: 11px;
		color: var(--fg-dim);
		margin-bottom: 10px;
		letter-spacing: 0.04em;
	}

	.accent {
		color: var(--accent);
	}

	.hero-name {
		font-size: clamp(32px, 8vw, 42px);
		font-weight: 700;
		line-height: 1;
		color: var(--fg);
		margin-bottom: 6px;
		letter-spacing: -0.03em;
	}

	.squiggle {
		display: inline-block;
		color: var(--accent);
		text-decoration: underline;
		text-decoration-style: wavy;
		text-decoration-color: var(--accent);
		text-underline-offset: 6px;
	}

	.hero-sub {
		font-size: 13px;
		color: var(--fg-muted);
		line-height: 1.7;
		max-width: 450px;
		margin: 18px 0 28px;
	}

	.hero-sub strong {
		color: var(--fg);
		font-weight: 700;
	}

	.cta-row {
		display: flex;
		gap: 10px;
		flex-wrap: wrap;
		margin-bottom: 24px;
	}

	.cta {
		padding: 9px 18px;
		font-family: var(--mono);
		font-size: 12px;
		font-weight: 700;
		cursor: pointer;
		border-radius: 3px;
		transition: all 0.12s ease;
		letter-spacing: 0.02em;
		text-decoration: none;
	}

	.cta-primary {
		background: var(--accent);
		color: #fff;
		border: none;
	}

	.cta-primary:hover {
		background: var(--accent-2);
		color: #fff;
	}

	.cta-ghost {
		background: transparent;
		color: var(--fg-muted);
		border: 1.5px dashed var(--border-2);
	}

	.cta-ghost:hover {
		border-color: var(--fg-dim);
		color: var(--fg);
	}

	.scroll-hint {
		font-size: 10px;
		color: var(--fg-dim);
		letter-spacing: 0.06em;
		margin-top: 8px;
	}

	/* Divider */
	.divider {
		display: flex;
		align-items: center;
		gap: 12px;
		padding: 0;
		margin: 4px 0 24px;
		font-family: var(--mono);
		font-size: 10px;
		color: var(--fg-dim);
		letter-spacing: 0.08em;
	}

	.divider::before,
	.divider::after {
		content: '';
		flex: 1;
		height: 1px;
		background: var(--border-2);
	}

	/* Section */
	.section {
		padding: 28px 0;
	}

	/* Post cards */
	.post-list {
		display: flex;
		flex-direction: column;
		gap: 14px;
	}

	.post-card {
		display: block;
		border: 1.5px dashed var(--border-2);
		border-radius: var(--radius);
		padding: 20px;
		cursor: pointer;
		transition: all 0.15s ease;
		text-decoration: none;
		color: inherit;
		position: relative;
		overflow: hidden;
	}

	.post-card:hover {
		background: var(--bg-card);
	}

	.post-meta {
		display: flex;
		align-items: center;
		gap: 10px;
		margin-bottom: 10px;
		flex-wrap: wrap;
	}

	.post-tag {
		font-size: 9px;
		font-weight: 700;
		padding: 2px 7px;
		border-radius: 2px;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		border: 1px solid;
	}

	.post-date {
		font-size: 10px;
		color: var(--fg-dim);
	}

	.post-title {
		font-size: 15px;
		font-weight: 700;
		color: var(--fg);
		margin-bottom: 6px;
		line-height: 1.3;
	}

	.post-excerpt {
		font-size: 11px;
		color: var(--fg-muted);
		line-height: 1.7;
	}

	.post-footer {
		margin-top: 12px;
		display: flex;
		align-items: center;
		justify-content: flex-end;
	}

	.post-arrow {
		font-size: 11px;
		color: var(--accent);
		opacity: 0;
		transition: opacity 0.15s ease;
	}

	.post-card:hover .post-arrow {
		opacity: 1;
	}

	/* View all */
	.view-all {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 0.5rem;
		margin-top: 2rem;
		font-family: var(--mono);
		font-size: 11px;
		color: var(--fg-dim);
		text-decoration: none;
		transition: color var(--transition);
	}

	.view-all:hover { color: var(--fg); }
	.view-all .arrow { transition: transform 0.25s ease; }
	.view-all:hover .arrow { transform: translateX(3px); }

	/* Empty state */
	.empty-state {
		padding: 2rem;
		background: rgba(0, 0, 0, 0.2);
		border-left: 2px solid var(--fg-dim);
		border-radius: 2px;
	}

	.empty-prompt {
		display: block;
		font-family: var(--mono);
		font-size: 11px;
		color: var(--fg-dim);
		margin-bottom: 0.5rem;
	}

	.empty-text {
		font-family: var(--mono);
		font-size: 11px;
		color: var(--fg-dim);
		margin: 0;
		opacity: 0.8;
	}

	@media (max-width: 640px) {
		.home-main { padding: 0 1rem; }
		.hero { padding: 32px 0 24px; }
		.cta-row { flex-direction: column; }
		.hero-name { font-size: 28px; }
	}
</style>
